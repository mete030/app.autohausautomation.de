generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CallbackStatus {
  offen
  in_bearbeitung
  erledigt
  ueberfaellig
}

enum CallbackPriority {
  niedrig
  mittel
  hoch
  dringend
}

enum CallSource {
  telefon
  website
  whatsapp
  ki_agent
  manuell
}

enum AgentType {
  mensch
  ki
}

enum CallbackEmailActionType {
  complete_callback
}

model CallbackRecord {
  id                 String                    @id @default(cuid())
  customerName       String
  customerPhone      String
  reason             String
  notes              String                    @default("")
  assignedAdvisor    String
  assignedEmployeeId String?
  status             CallbackStatus            @default(offen)
  priority           CallbackPriority
  source             CallSource
  takenById          String
  takenByName        String
  takenByType        AgentType
  callTranscript     String?
  callDuration       Int?
  slaDurationMinutes Int
  dueAt              DateTime
  slaDeadline        DateTime
  completionNotes    String?
  completedAt        DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  activities         CallbackActivityRecord[]
  emailActions       CallbackEmailActionRecord[]
  attachments        CallbackAttachmentRecord[]

  @@index([status, createdAt])
  @@index([assignedEmployeeId])
}

model CallbackAttachmentRecord {
  id             String         @id @default(cuid())
  callbackId     String
  fileName       String
  mimeType       String
  fileSizeBytes  Int
  storagePath    String
  stage          String
  uploadedByName String
  uploadedByRole String
  createdAt      DateTime       @default(now())
  callback       CallbackRecord @relation(fields: [callbackId], references: [id], onDelete: Cascade)

  @@index([callbackId, stage])
}

model CallbackActivityRecord {
  id          String         @id @default(cuid())
  callbackId  String
  type        String
  description String
  performedBy String
  performedAt DateTime       @default(now())
  metadata    Json?
  callback    CallbackRecord @relation(fields: [callbackId], references: [id], onDelete: Cascade)

  @@index([callbackId, performedAt])
}

model CallbackEmailActionRecord {
  id             String                  @id @default(cuid())
  callbackId     String
  actionType     CallbackEmailActionType
  recipientEmail String
  recipientName  String
  tokenHash      String                  @unique
  expiresAt      DateTime
  usedAt         DateTime?
  usedByIp       String?
  invalidatedAt  DateTime?
  createdAt      DateTime                @default(now())
  callback       CallbackRecord          @relation(fields: [callbackId], references: [id], onDelete: Cascade)

  @@index([callbackId, actionType])
  @@index([expiresAt])
}

// =====================================================================
// KI-Rezeptionist (Famulor) — VOLLSTÄNDIG ISOLIERT.
// Eigene Tabelle, keine Relation zu CallbackRecord. /callcenter liest
// ausschließlich CallbackRecord und kann diese Zeilen daher nie sehen.
// =====================================================================

enum KiReceptionStatus {
  offen
  in_bearbeitung
  erledigt
}

enum KiReceptionCategory {
  neuwagen
  gebrauchtwagen
  probefahrt
  finanzierung_leasing
  inzahlungnahme
  werkstatt_service
  beschwerde
  sonstiges
}

model KiReceptionCallRecord {
  id              String              @id @default(cuid())
  externalCallId  String?             @unique // Famulor Call-ID → Idempotenz bei Webhook-Retries
  customerName    String              @default("Unbekannt")
  customerPhone   String              @default("")
  category        KiReceptionCategory @default(sonstiges)
  summary         String              @default("") // Kurz-Zusammenfassung der KI
  vehicle         String? // genanntes Wunschmodell/Fahrzeug
  desiredAppt     String? // Wunschtermin (Probefahrt/Werkstatt)
  transcript      String?
  recordingUrl    String?
  callDurationSec Int?
  status          KiReceptionStatus   @default(offen)
  assignedTo      String? // optionaler Bearbeiter; null = offener Vertriebs-Pool
  completionNotes String?
  completedAt     DateTime?
  completedBy     String?
  receivedAt      DateTime            @default(now()) // wann der Anruf reinkam
  rawPayload      Json? // roher Famulor-Webhook (Debug/Audit)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status, receivedAt])
  @@index([category])
}

// =====================================================================
// KI-Kalender — Termine & Schließzeiten. Ebenfalls vollständig isoliert:
// keine Relation/FK zu CallbackRecord oder KiReceptionCallRecord.
// =====================================================================

enum KiAppointmentStatus {
  geplant
  bestaetigt
  abgesagt
  erledigt
}

enum KiAppointmentSource {
  manuell // vom Mitarbeiter angelegt
  ki_wunsch // aus Famulor desiredAppt abgeleitet (tentativ)
  ki_gebucht // von einem Buchungs-Agent gebucht (Webhook)
  api
}

enum KiClosureType {
  betriebsschliessung
  urlaub
  wartung
  feiertag
}

model KiAppointment {
  id            String               @id @default(cuid())
  externalId    String?              @unique // Idempotenz für Buchungs-Webhook
  customerName  String               @default("Unbekannt")
  customerPhone String?
  category      KiReceptionCategory?
  service       String               @default("") // z.B. "Probefahrt", "Inspektion"
  location      String               @default("Nagold")
  staff         String? // zugewiesener Mitarbeiter
  startTime     DateTime
  endTime       DateTime
  priceCents    Int? // Gesamt in Cent
  notesPublic   String? // für Empfangsmitarbeiter sichtbar
  notesInternal String? // nur intern
  status        KiAppointmentStatus  @default(geplant)
  source        KiAppointmentSource  @default(manuell)
  sourceCallId  String? // optionale Referenz auf KiReceptionCallRecord.id (KEIN FK → Isolation)
  rawPayload    Json?
  createdBy     String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([startTime, location])
  @@index([status, startTime])
}

model KiLocationClosure {
  id        String        @id @default(cuid())
  location  String        @default("Nagold")
  type      KiClosureType @default(betriebsschliessung)
  name      String        @default("")
  allDay    Boolean       @default(true)
  startDate DateTime
  endDate   DateTime
  reason    String?
  createdBy String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([location, startDate])
}
